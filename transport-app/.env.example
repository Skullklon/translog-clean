# ─────────────────────────────────────────────────────────────
# Nexura RD Transport App — environment variables
# Copy this file to `.env` for local dev and fill in real values.
# NEVER commit `.env` to git — it is in `.gitignore`.
# ─────────────────────────────────────────────────────────────

# --- Runtime ---
NODE_ENV=development             # development | production
PORT=4000                        # API port; Nginx will reverse-proxy 443 → this
APP_URL=http://localhost:4000    # Public URL of the app (used in emails, CORS)

# --- Database (PostgreSQL) ---
# Single URL form, recommended:
DATABASE_URL=postgres://nexura:CHANGE_ME@localhost:5432/nexura_transport

# Or individual fields (used if DATABASE_URL is not set):
# PGHOST=localhost
# PGPORT=5432
# PGDATABASE=nexura_transport
# PGUSER=nexura
# PGPASSWORD=CHANGE_ME

# --- Auth ---
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-hex-string
JWT_EXPIRES_IN=12h
BCRYPT_ROUNDS=12

# --- CORS ---
# Comma-separated list of allowed origins. Use exact origins, no wildcards in production.
CORS_ORIGINS=http://localhost:4000,https://app.nexorard.org,https://nexorard.org

# --- Rate limiting ---
RATE_LIMIT_WINDOW_MS=900000      # 15 minutes
RATE_LIMIT_MAX=300               # requests per window per IP

# --- Logging ---
LOG_LEVEL=info                   # error | warn | info | debug
